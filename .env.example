## ---------------------------------------------------------------
## MakeIt // HQ — environment
## ---------------------------------------------------------------
## Copy to .env.local (NEVER commit) and fill in real values.
## When these are missing, the app runs in demo mode with mock data
## and the cookie-based invite-code login.

# Supabase project — find these in
# https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Used by the Stripe webhook (server-side only — never expose).
# https://supabase.com/dashboard/project/_/settings/api → service_role
SUPABASE_SERVICE_ROLE_KEY=

# Stripe — required for billing. Without these the app stays in
# "demo mode" and the checkout/portal buttons just show a banner.
# Test keys live at https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs (created from your Products dashboard)
# crew         = monthly Crew membership
# one_on_one   = 1:1 coaching add-on
STRIPE_PRICE_CREW=
STRIPE_PRICE_ONE_ON_ONE=

# Anthropic — when set, the onboarding program generator calls Claude
# (Sonnet 4.6) for personalised programs. If missing, the rule-based
# generator is used. Get a key at https://console.anthropic.com.
ANTHROPIC_API_KEY=

# Resend — transactional email (coach-review notifications, etc).
# Without these, the action just skips sending. Sign up at resend.com.
# RESEND_FROM_EMAIL must be from a domain you've verified in Resend
# (or use 'onboarding@resend.dev' for testing — only sends to your
# own account email).
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_REPLY_TO=
